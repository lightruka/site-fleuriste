}

.site-card-link:hover .card {
  transform: translateY(-5px);
  box-shadow: 0 14px 28px rgba(0, 0, 0, 0.12);
}

.site-card-link .card h3 {
  display: inline-block;
  position: relative;
}

.logo::after,
.top-contact-link::after,
.nav-links a::after,
.site-card-link .card h3::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -3px;
  height: 1px;
  background: currentColor;
  transform: scaleX(0);
  transform-origin: center;
  transition: transform 0.3s ease;
}

.logo:hover::after,
.top-contact-link:hover::after,
.nav-links a:hover::after,
.nav-links a.active::after,
.site-card-link:hover .card h3::after {
  transform: scaleX(1);
}

.card:hover {
  transform: translateY(-4px);
  box-shadow: 0 14px 28px rgba(0, 0, 0, 0.12);
}

.card:hover img {
  transform: scale(1.03);
}

.click-tip {
  font-style: italic;
  margin-top: -8px;
}

.product-category-card {
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.product-category-card:hover {
  transform: translateY(-3px);
}

.product-category-card.active {
  box-shadow: 0 0 0 2px #b9d3ba, var(--shadow);
}

.product-description-panel {
  margin-top: 18px;
}

.product-examples {
  padding-top: 28px;
}

.bouquet-example-card {
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.bouquet-example-card:hover {
  transform: translateY(-3px);
}

.card-tag {
  display: inline-block;
  margin-bottom: 8px;
  padding: 4px 10px;
  border-radius: 999px;
  background: #f9edf1;
  color: #875a67;
  font-size: 0.8rem;
  font-weight: 700;
}

.detail-layout {
  margin-top: 18px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  align-items: start;
}

.detail-layout img {
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  width: 100%;
  min-height: 340px;
  object-fit: cover;
}

/* Subtle page-load reveal animation */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(14px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero,
.section {
  animation: fadeUp 0.55s ease both;
}

.section:nth-of-type(2) {
  animation-delay: 0.06s;
}

.section:nth-of-type(3) {
  animation-delay: 0.12s;
}

.section:nth-of-type(4) {
  animation-delay: 0.18s;
}

.section:nth-of-type(5) {
  animation-delay: 0.24s;
}

@media (prefers-reduced-motion: reduce) {
  html {
    scroll-behavior: auto;
  }

  .hero,
  .section {
    animation: none;
  }

  .btn,
  .card,
  .card img,
  .site-card-link .card {
    transition: none;
  }
}

@media (max-width: 1100px) {
  .hero {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .hero img {
    min-height: 280px;
  }

  .site-links-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 900px) {
  .hero,
  .cards,
  .trust-grid,
  .detail-layout,
  .about-grid,
  .contact-grid {
    grid-template-columns: 1fr;
  }

  .hero {
    margin-top: 18px;
  }

  .section {
    padding: 40px 0;
  }

  .site-title-banner {
    min-height: 180px;
  }

  .final-cta {
    padding: 26px 14px;
  }
}

@media (max-width: 700px) {
  .nav-wrap {
    min-height: 64px;
  }

  .menu-btn {
    display: inline-block;
    font-size: 1.15rem;
    padding: 6px 9px;
  }

  .top-contact-link {
    font-size: 0.95rem;
  }

  .logo-icon {
    width: 24px;
    height: 24px;
  }

  .nav-links {
    position: absolute;
    right: 4%;
    top: 64px;
    background: #fff;
    border: 1px solid #eadfe3;
    border-radius: 12px;
    box-shadow: var(--shadow);
    width: min(92vw, 260px);
    display: none;
    flex-direction: column;
    align-items: flex-start;
    padding: 8px 12px;
    gap: 8px;
  }

  .nav-links.open {
    display: flex;
  }

  .nav-links a {
    width: 100%;
    padding: 6px 0;
    font-size: 0.95rem;
  }

  .site-links-grid {
    grid-template-columns: 1fr;
  }

  .mobile-tap-hint {
    display: block;
  }

  .hero-content h1 {
    font-size: clamp(1.45rem, 7vw, 1.8rem);
  }

  .tagline {
    font-size: 0.95rem;
  }

  .btn {
    width: auto;
    text-align: center;
    padding: 9px 16px;
    font-size: 0.92rem;
  }

  .hero-cta-group {
    flex-direction: column;
    align-items: stretch;
  }

  .card img {
    height: 180px;
  }

  .card-body {
    padding: 13px;
  }

  .card p {
    font-size: 0.95rem;
  }
}

@media (max-width: 480px) {
  .container {
    width: 94%;
  }

  .section {
    padding: 26px 0;
  }

  .site-title-banner {
    min-height: 130px;
    padding: 12px;
  }

  .site-title-large {
    font-size: clamp(1.5rem, 9vw, 2.1rem);
  }

  .section-intro {
    margin-bottom: 18px;
    font-size: 0.94rem;
  }

  .card img {
    height: 165px;
  }
}

