@import url("https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&display=swap");

:root {
  --green: #7aa37a;
  --green-dark: #4f7450;
  --pink: #f6d7df;
  --pink-dark: #d99cab;
  --white: #ffffff;
  --text: #2f3a2f;
  --muted: #6f7b6f;
  --shadow: 0 8px 22px rgba(0, 0, 0, 0.08);
  --radius: 16px;
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  padding: 0;
  font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
  color: var(--text);
  background: linear-gradient(180deg, #fff 0%, #fdf8fa 100%);
}

html {
  scroll-behavior: smooth;
}

img {
  max-width: 100%;
  display: block;
}

a {
  color: inherit;
  text-decoration: none;
}

.container {
  width: min(1100px, 92%);
  margin: 0 auto;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid #f0e6ea;
}

.nav-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 74px;
}

.logo {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: clamp(1.05rem, 2.6vw, 1.2rem);
  font-weight: 700;
  color: var(--green-dark);
  position: relative;
  padding-bottom: 2px;
}

.logo-icon {
  width: 28px;
  height: 28px;
  flex-shrink: 0;
}

.top-contact-link {
  display: inline-block;
  font-weight: 600;
  color: var(--text);
  padding: 6px 2px;
  position: relative;
  transition: color 0.25s ease;
  padding-bottom: 2px;
}

.top-contact-link:hover {
  color: var(--green-dark);
}

.nav-links {
  display: flex;
  gap: 22px;
  align-items: center;
}

.nav-links a {
  display: inline-block;
  font-weight: 600;
  color: var(--text);
  padding: 6px 2px;
  position: relative;
  transition: color 0.25s ease;
}

.nav-links a:hover,
.nav-links a.active {
  color: var(--green-dark);
}

.menu-btn {
  display: none;
  border: none;
  background: var(--pink);
  color: var(--green-dark);
  font-size: 1.3rem;
  border-radius: 10px;
  padding: 8px 10px;
  cursor: pointer;
}

.hero {
  margin: 24px auto 48px;
  display: grid;
  gap: 30px;
  grid-template-columns: 1.1fr 0.9fr;
  align-items: center;
}

.hero-content h1 {
  font-size: clamp(1.9rem, 3.5vw, 3rem);
  margin: 0 0 14px;
  color: var(--green-dark);
}

.tagline {
  font-size: 1.15rem;
  color: var(--muted);
  margin-bottom: 18px;
}

.hero-content p {
  margin: 0 0 22px;
  line-height: 1.7;
}

.hero-cta-group {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.btn {
  display: inline-block;
  border: none;
  border-radius: 999px;
  padding: 11px 20px;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.25s ease, opacity 0.25s ease, box-shadow 0.25s ease;
}

.btn:hover {
  transform: translateY(-2px) scale(1.01);
  opacity: 0.96;
  box-shadow: 0 10px 18px rgba(79, 116, 80, 0.18);
}

.btn-primary {
  background: var(--green);
  color: var(--white);
}

.btn-secondary {
  background: var(--pink);
  color: #5c3f48;
}

.hero img {
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  min-height: 340px;
  object-fit: cover;
}

.section {
  padding: 52px 0;
}

.section h2 {
  font-size: clamp(1.5rem, 2.4vw, 2.2rem);
  margin: 0 0 18px;
  color: var(--green-dark);
}

.section-intro {
  color: var(--muted);
  margin: 0 0 24px;
}

.cards {
  display: grid;
  gap: 18px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.card {
  background: var(--white);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.card img {
  height: 220px;
  width: 100%;
  object-fit: cover;
  transition: transform 0.45s ease;
}

.card-body {
  padding: 16px;
}

.card h3 {
  margin: 0 0 8px;
  color: var(--green-dark);
}

.card p {
  margin: 0;
  color: var(--muted);
  line-height: 1.6;
}

.price-note {
  margin-top: 10px !important;
  color: var(--green-dark) !important;
  font-weight: 700;
}

.trust-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14px;
}

.trust-item {
  padding: 16px;
}

.trust-item h3 {
  margin: 0 0 8px;
  color: var(--green-dark);
  font-size: 1rem;
}

.reviews-grid .card {
  border-top: 4px solid #d8ebd9;
}

.faq-list {
  display: grid;
  gap: 12px;
}

.final-cta {
  text-align: center;
  background: #f8fcf8;
  border: 1px solid #e2efe2;
  border-radius: var(--radius);
  padding: 36px 20px;
}

.final-cta .hero-cta-group {
  justify-content: center;
}

.about-grid,
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}

.panel {
  background: #fff;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 20px;
}

.contact-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.contact-list li {
  margin-bottom: 10px;
  color: var(--muted);
}

.form-group {
  margin-bottom: 14px;
}

label {
  display: block;
  margin-bottom: 6px;
  font-weight: 600;
}

input,
textarea {
  width: 100%;
  border: 1px solid #e1d8dc;
  border-radius: 10px;
  padding: 10px 12px;
  font: inherit;
  font-size: 16px;
}

textarea {
  min-height: 130px;
  resize: vertical;
}

.map-frame {
  width: 100%;
  min-height: 260px;
  border: 0;
  border-radius: 12px;
}

.site-footer {
  margin-top: 40px;
  border-top: 1px solid #ece2e7;
  padding: 20px 0;
  color: var(--muted);
  text-align: center;
}

.site-footer a {
  color: var(--green-dark);
  font-weight: 600;
}

.site-footer a:hover {
  text-decoration: underline;
}

.site-title-banner {
  margin-bottom: 24px;
  background: linear-gradient(135deg, #f4fff4 0%, #fdeff4 100%);
  border: 1px solid #ebdce2;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  min-height: 220px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  align-items: center;
  justify-content: center;
}

.site-title-large {
  margin: 0;
  color: var(--green-dark);
  font-family: "Playfair Display", Georgia, "Times New Roman", serif;
  font-size: clamp(2rem, 6vw, 4.2rem);
  letter-spacing: 1px;
  text-align: center;
}

.site-slogan {
  margin: 0;
  color: #5f6e5f;
  font-size: clamp(1rem, 2.2vw, 1.25rem);
  font-style: italic;
  text-align: center;
}


.site-links-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.site-card-link {
  display: block;
  color: inherit;
  border-radius: var(--radius);
}

.site-card-link .card {
  height: 100%;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.site-card-link:hover .card {
  transform: translateY(-5px);
  box-shadow: 0 14px 28px rgba(0, 0, 0, 0.12);
}

.site-card-link .card h3 {
  display: inline-block;
  position: relative;
}

.logo::after,
.top-contact-link::after,
.nav-links a::after,
.site-card-link .card h3::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -3px;
  height: 1px;
  background: currentColor;
  transform: scaleX(0);
  transform-origin: center;
  transition: transform 0.3s ease;
}

.logo:hover::after,
.top-contact-link:hover::after,
.nav-links a:hover::after,
.nav-links a.active::after,
.site-card-link:hover .card h3::after {
  transform: scaleX(1);
}

.card:hover {
  transform: translateY(-4px);
  box-shadow: 0 14px 28px rgba(0, 0, 0, 0.12);
}

.card:hover img {
  transform: scale(1.03);
}

.click-tip {
  font-style: italic;
  margin-top: -8px;
}

.product-category-card {
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.product-category-card:hover {
  transform: translateY(-3px);
}

.product-category-card.active {
  box-shadow: 0 0 0 2px #b9d3ba, var(--shadow);
}

.product-description-panel {
  margin-top: 18px;
}

.product-examples {
  padding-top: 28px;
}

.bouquet-example-card {
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.bouquet-example-card:hover {
  transform: translateY(-3px);
}

.card-tag {
  display: inline-block;
  margin-bottom: 8px;
  padding: 4px 10px;
  border-radius: 999px;
  background: #f9edf1;
  color: #875a67;
  font-size: 0.8rem;
  font-weight: 700;
}

.detail-layout {
  margin-top: 18px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  align-items: start;
}

.detail-layout img {
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  width: 100%;
  min-height: 340px;
  object-fit: cover;
}

/* Subtle page-load reveal animation */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(14px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero,
.section {
  animation: fadeUp 0.55s ease both;
}

.section:nth-of-type(2) {
  animation-delay: 0.06s;
}

.section:nth-of-type(3) {
  animation-delay: 0.12s;
}

.section:nth-of-type(4) {
  animation-delay: 0.18s;
}

.section:nth-of-type(5) {
  animation-delay: 0.24s;
}

@media (prefers-reduced-motion: reduce) {
  html {
    scroll-behavior: auto;
  }

  .hero,
  .section {
    animation: none;
  }

  .btn,
  .card,
  .card img,
  .site-card-link .card {
    transition: none;
  }
}

@media (max-width: 1100px) {
  .hero {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .hero img {
    min-height: 280px;
  }

  .site-links-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 900px) {
  .hero,
  .cards,
  .trust-grid,
  .detail-layout,
  .about-grid,
  .contact-grid {
    grid-template-columns: 1fr;
  }

  .hero {
    margin-top: 18px;
  }

  .section {
    padding: 40px 0;
  }

  .site-title-banner {
    min-height: 180px;
  }

  .final-cta {
    padding: 26px 14px;
  }
}

@media (max-width: 700px) {
  .nav-wrap {
    min-height: 64px;
  }

  .menu-btn {
    display: inline-block;
    font-size: 1.15rem;
    padding: 6px 9px;
  }

  .top-contact-link {
    font-size: 0.95rem;
  }

  .logo-icon {
    width: 24px;
    height: 24px;
  }

  .nav-links {
    position: absolute;
    right: 4%;
    top: 64px;
    background: #fff;
    border: 1px solid #eadfe3;
    border-radius: 12px;
    box-shadow: var(--shadow);
    width: min(92vw, 260px);
    display: none;
    flex-direction: column;
    align-items: flex-start;
    padding: 8px 12px;
    gap: 8px;
  }

  .nav-links.open {
    display: flex;
  }

  .nav-links a {
    width: 100%;
    padding: 6px 0;
    font-size: 0.95rem;
  }

  .site-links-grid {
    grid-template-columns: 1fr;
  }

  .hero-content h1 {
    font-size: clamp(1.45rem, 7vw, 1.8rem);
  }

  .tagline {
    font-size: 0.95rem;
  }

  .btn {
    width: auto;
    text-align: center;
    padding: 9px 16px;
    font-size: 0.92rem;
  }

  .hero-cta-group {
    flex-direction: column;
    align-items: stretch;
  }

  .card img {
    height: 180px;
  }

  .card-body {
    padding: 13px;
  }

  .card p {
    font-size: 0.95rem;
  }
}

@media (max-width: 480px) {
  .container {
    width: 94%;
  }

  .section {
    padding: 26px 0;
  }

  .site-title-banner {
    min-height: 130px;
    padding: 12px;
  }

  .site-title-large {
    font-size: clamp(1.5rem, 9vw, 2.1rem);
  }

  .section-intro {
    margin-bottom: 18px;
    font-size: 0.94rem;
  }

  .card img {
    height: 165px;
  }
}

